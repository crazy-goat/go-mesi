# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.a

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Coverage reports and profiles
coverage.html
*.coverprofile

# Debug binaries generated by IDEs
__debug_bin*

# macOS filesystem artifacts
.DS_Store

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Compiled binaries
cli/cli
tests/tests

.idea
/servers/test-server/example-server
/libgomesi/test-libgomesi
/servers/nginx/libgomesi.h
/servers/nginx/build/
/libgomesi/libgomesi.h
/cli/mesi-cli
/tests/e2e
/tests/test-server
/servers/roadrunner/rr
/servers/roadrunner/worker/vendor/
/servers/roadrunner/worker/composer.lock
/servers/caddy/caddy
/obj-x86_64-linux-gnu/
/debian/.debhelper/
/debian/go-mesi/
/debian/libgomesi/
/debian/libgomesi-dev/
/servers/frankenphp/frankenphp

# Sub-module build artifacts
cli/go.sum
servers/proxy/proxy
servers/roadrunner/go.sum
servers/traefik/go.sum

# Agent skills and specs (local development)
.agents/
docs/superpowers/
skills-lock.json

# Manual test files
libgomesi/test-libgomesi.c.manual

# Apache module build artifacts
servers/apache/.libs/
servers/apache/*.la
servers/apache/*.lo
servers/apache/*.slo
servers/apache/tests/test.txt
